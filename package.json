{
  "name": "lilly-75-holy",
  "version": "0.1.2",
  "private": true,
  "description": "75-day Christian discipline tracker for Lilly Grace + Ellie",
  "license": "MIT",
  "author": "Jeremy Longshore",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "tsx scripts/migrate.ts",
    "invite": "tsx scripts/generate-invite-code.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "next": "15.0.3",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "better-sqlite3": "11.5.0",
    "bcryptjs": "2.4.3",
    "zod": "3.23.8",
    "clsx": "2.1.1",
    "tailwind-merge": "2.5.4"
  },
  "devDependencies": {
    "@intentsolutions/audit-harness": "^0.1.0",
    "@types/better-sqlite3": "7.6.12",
    "@types/bcryptjs": "2.4.6",
    "@types/node": "22.9.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "10.4.20",
    "eslint": "9.16.0",
    "eslint-config-next": "15.0.3",
    "husky": "9.1.7",
    "postcss": "8.4.49",
    "tailwindcss": "3.4.15",
    "tsx": "4.19.2",
    "typescript": "5.7.2",
    "vitest": "2.1.8"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "bcryptjs"
    ]
  }
}
